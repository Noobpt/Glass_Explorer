{
  "$schema": "https://raw.githubusercontent.com/nicepkg/gpt-runner/refs/heads/main/packages/gpt-runner-web/scripts/tauri.conf.schema.json",
  "productName": "GlassExplorer",
  "identifier": "com.glass-explorer.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "GlassExplorer",
        "width": 320,
        "height": 480,
        "minWidth": 200,
        "minHeight": 300,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
              "skipTaskbar": true
      }
    ],
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "GlassExplorer"
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}
